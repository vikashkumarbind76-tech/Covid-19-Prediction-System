# ==========================================
# COVID-19 Prediction System - Env Config
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# --- Flask Configuration ---
# Generate a strong SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING

# Choose a strong admin password (not your name!)
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

PORT=5000

# --- CORS (Production) ---
# Set this to your deployed domain to lock down the API.
# Example: https://my-covid-app.vercel.app
# Leave as * for local development only.
CORS_ORIGIN=*

# --- Supabase (PostgreSQL) - for Vercel/Production ---
# Get this from: Supabase Dashboard → Project Settings → Database → URI tab
# Use the POOLER URL (port 6543) for Vercel serverless deployments.
# Leave blank to use local SQLite (for local development).
DATABASE_URL=

# --- SQLite Database Paths (local development only) ---
# Ignored when DATABASE_URL is set.
DB_PATH=predictions.db
DB_PATH_STREAMLIT=covid_health.db
